[user]
    name = YOUR_NAME
    email = YOUR_EMAIL

[init]
    defaultBranch = main

[pull]
    rebase = false

[push]
    autoSetupRemote = true
    default = current

[fetch]
    prune = true

[merge]
    conflictStyle = zdiff3

[diff]
    colorMoved = default

[core]
    editor = code --wait
    pager = delta
    autocrlf = input
    excludesfile = ~/.gitignore_global

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    syntax-theme = GitHub
    features = decorations

[delta "decorations"]
    commit-decoration-style = blue ol
    commit-style = raw
    file-style = yellow
    file-decoration-style = none
    hunk-header-decoration-style = blue box

[color]
    ui = auto

[rerere]
    enabled = true

[help]
    autocorrect = prompt

[credential]
    helper = osxkeychain

[alias]

    st = status

    br = branch

    co = checkout

    sw = switch

    ci = commit

    ca = commit --amend

    last = log -1 HEAD

    lg = log --graph --decorate --oneline --all

    hist = log --graph --pretty=format:'%C(auto)%h %Cgreen%ad %Creset%s %Cblue[%an]' --date=short

    df = diff

    dc = diff --cached

    unstage = restore --staged

    aliases = config --get-regexp '^alias\.'

[tag]
    sort = version:refname

[branch]
    sort = -committerdate

[gpg]
    format = ssh

[commit]
    gpgsign = false

[github]
    user = YOUR_GITHUB_USERNAME